#!/bin/sh
# Git pre-commit hook：检查 CHANGELOG.md 是否已更新
# 安装方法：将此文件复制到 .git/hooks/pre-commit 并赋予执行权限
# 或使用 install-hooks.sh 自动安装

# 获取暂存区中修改的文件
STAGED_FILES=$(git diff --cached --name-only)

# 检查是否有非文档类的代码变更
NON_DOC_CHANGES=$(echo "$STAGED_FILES" | grep -vE "^(docs/|\.github/|README|\.vscode/|\.gitignore|CHANGELOG)" || true)

if [ -z "$NON_DOC_CHANGES" ]; then
  # 无代码变更，放行
  exit 0
fi

# 有代码变更，检查 CHANGELOG.md 是否在暂存区
if echo "$STAGED_FILES" | grep -q "^CHANGELOG.md$"; then
  echo "✅ CHANGELOG.md 已更新，提交通过"
  exit 0
else
  echo ""
  echo "❌ [pre-commit] CHANGELOG.md 未更新！"
  echo ""
  echo "检测到以下代码变更："
  echo "$NON_DOC_CHANGES" | sed 's/^/  - /'
  echo ""
  echo "请在提交前更新 CHANGELOG.md，然后将其加入暂存区："
  echo ""
  echo "  git add CHANGELOG.md"
  echo ""
  echo "如果本次提交确实不需要更新 CHANGELOG（如 WIP 提交），可跳过检查："
  echo ""
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi
